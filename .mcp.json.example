{
  "mcpServers": {
    "sonarqube": {
      "command": "docker",
      "args": [
        "run", "--init", "--pull=always", "-i", "--rm",
        "-e", "SONARQUBE_TOKEN",
        "-e", "SONARQUBE_URL",
        "-e", "SONARQUBE_PROJECT_KEY",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_URL": "http://host.docker.internal:9000",
        "SONARQUBE_TOKEN": "",
        "SONARQUBE_PROJECT_KEY": "auth-service"
      }
    }
  }
}
