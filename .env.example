# Runtime ports
AUTH_API_PORT=4000
POSTGRES_PORT=5432
OPENSEARCH_PORT=9200
OPENSEARCH_METRICS_PORT=9600

# Integration: PostgreSQL
POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=auth;Username=postgres;Password=postgres

# Integration: OpenSearch
# Local OpenSearch in compose profile: use http://opensearch:9200
# External OpenSearch: replace with your endpoint, for example http://opensearch.company.local:9200
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_PREFIX=auth
OPENSEARCH_ENSURE_INDICES_ON_STARTUP=true
OPENSEARCH_REINDEX_ON_STARTUP=false
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# Integration: CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Integration: Verification URLs (substituted into email/sms templates as {{link}})
VERIFICATION_EMAIL_BASE_URL=http://localhost:4000/auth/verify.html?type=email
VERIFICATION_PHONE_BASE_URL=http://localhost:4000/auth/verify.html?type=phone

# Integration: 2FA (AES-GCM encryption for OTP codes and sensitive fields, min 32 chars)
ENCRYPTION_KEY=

# Integration: SMTP (2FA email delivery)
SMTP_ENABLED=true
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@auth-service
SMTP_FROM_NAME=Auth Service

# Integration: SMS Gateway (2FA SMS delivery)
SMS_GATEWAY_ENABLED=true
SMS_GATEWAY_BASE_URL=http://host.docker.internal:5075
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_TIMEOUT_SECONDS=5

# Integration: Cleanup (0 = disabled)
INTEGRATION__CLEANUP__SESSIONS__INTERVALMINUTES=60
INTEGRATION__CLEANUP__SESSIONS__RETENTIONDAYS=7
INTEGRATION__CLEANUP__SESSIONS__BATCHSIZE=1000
INTEGRATION__CLEANUP__TWOFACTORCHALLENGES__INTERVALMINUTES=30
INTEGRATION__CLEANUP__TWOFACTORCHALLENGES__RETENTIONHOURS=24
INTEGRATION__CLEANUP__TWOFACTORCHALLENGES__BATCHSIZE=1000
INTEGRATION__CLEANUP__PASSWORDCHANGECHALLENGES__INTERVALMINUTES=30
INTEGRATION__CLEANUP__PASSWORDCHANGECHALLENGES__RETENTIONHOURS=24
INTEGRATION__CLEANUP__PASSWORDCHANGECHALLENGES__BATCHSIZE=1000
INTEGRATION__CLEANUP__AUDITLOG__INTERVALMINUTES=1440
INTEGRATION__CLEANUP__AUDITLOG__RETENTIONDAYS=365
INTEGRATION__CLEANUP__AUDITLOG__BATCHSIZE=1000

# Integration: Rate Limit (0 = disabled)
INTEGRATION__RATELIMIT__AUTH__PERMITLIMIT=10
INTEGRATION__RATELIMIT__AUTH__WINDOWSECONDS=900
INTEGRATION__RATELIMIT__TWOFACTOR__PERMITLIMIT=5
INTEGRATION__RATELIMIT__TWOFACTOR__WINDOWSECONDS=3600
INTEGRATION__RATELIMIT__GLOBAL__PERMITLIMIT=0
INTEGRATION__RATELIMIT__GLOBAL__WINDOWSECONDS=60

# SonarQube
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=
SONAR_PROJECT_KEY=auth-service
